{
  "name": "ava-typescript-basic",
  "description": "Basic example for AVA with TypeScript",
  "scripts": {
    "test": "rimraf ./build && ava"
  },
  "devDependencies": {
    "@ava/typescript": "^5.0.0",
    "@sindresorhus/tsconfig": "^7.0.0",
    "@types/jsonfile": "^6.1.4",
    "ava": "^6.2.0",
    "typescript": "^5.8.2"
  },
  "ava": {
    "typescript": {
      "compile": "tsc",
      "rewritePaths": {
        "source/": "build/"
      }
    }
  },
  "dependencies": {
    "jsonfile": "^6.1.0",
    "minimist": "^1.2.8",
    "rimraf": "^6.0.1"
  }
}
